# ===========================================
# STELE Production Configuration
# ===========================================
# Copy to .env and fill in your values

# --- World ID (Developer Portal: https://developer.world.org/) ---
WORLD_ID_APP_ID=app_xxxxxxxxxxxxx
WORLD_ID_RP_ID=rp_xxxxxxxxxxxxx
WORLD_ID_ACTION=stele-inscribe
RP_SIGNING_KEY=xxxxxxxxxxxxx

# --- Frontend (Vite) - prefix with VITE_ for client exposure ---
VITE_WORLD_ID_APP_ID=app_xxxxxxxxxxxxx
VITE_WORLD_ID_RP_ID=rp_xxxxxxxxxxxxx
VITE_WORLD_ID_ACTION=stele-inscribe
# staging = Simulator | production = World App (default)
VITE_WORLD_ID_ENV=staging

# --- Storacha (Create Space + delegation via CLI) ---
# 1. npm install -g @storacha/cli
# 2. storacha login <email>
# 3. storacha space create (or use existing)
# 4. storacha key create  -> save output as STORACHA_KEY
# 5. storacha delegation create <did_from_step_4> --base64  -> save as STORACHA_PROOF
STORACHA_KEY=Mgxxxxxxxxxxxxx
STORACHA_PROOF=xxxxxxxxxxxxx

# --- Pinata (IPFS backup pinning: https://app.pinata.cloud/developers/api-keys) ---
PINATA_JWT=xxxxxxxxxxxxx

# --- Server ---
PORT=3001
# CORS: domain production (e.g. https://stele.example.com) atau kosong = allow all
# ALLOWED_ORIGIN=https://stele.example.com
